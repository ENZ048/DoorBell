# --- Public hostnames -------------------------------------------------------
# Two subdomains, both pointed at the same EC2 elastic IP. Caddy serves
# the React build under DOMAIN_WEB and reverse-proxies the API under
# DOMAIN_API.
DOMAIN_WEB=doorbell.chatroute.in
DOMAIN_API=api.chatroute.in

# Used by the backend when constructing/identifying its own URL.
PUBLIC_BASE_URL=https://api.chatroute.in

# Comma-separated list of allowed CORS origins (the dashboard's URL).
CORS_ORIGINS=https://doorbell.chatroute.in

# --- MongoDB Atlas (M0 free tier, ap-south-1) -------------------------------
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=riya

# --- Bolna voice agent ------------------------------------------------------
BOLNA_API_KEY=
BOLNA_AGENT_ID=
BOLNA_WEBHOOK_SECRET=
BOLNA_BASE_URL=https://api.bolna.ai

# --- Admin (server-side endpoints; not surfaced in the seller UI) ----------
ADMIN_TOKEN=
